<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/home.css">
</head>

<body>
    <h3>All Listings</h3>
    
    <form method="get" action="http://localhost:8080/listing/new">
        <button type="submit">add new</button>
    </form>

    <hr> 
    
    <% for(let list of lists){%>
        <li><a  href="http://localhost:8080/listing/<%= list._id %>">
            <%= list.title %>
        </a>
        <form method="get" action="http://localhost:8080/listing/update/<%= list._id %>">
            <button>Update</button>
        </form>
        <form method="post" action="http://localhost:8080/<%= list._id %>?_method=Delete">
            <button>Delete</button>
        </form>
    </li>
        <%}%>
</body>

</html>