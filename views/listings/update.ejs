<% layout("layouts/boilarplate") %>
<body>
    <form method="post" action="http://localhost:8080/<%= listing._id %>?_method=Patch">
        <label for="title">Title: </label>
        <input type="text" name="listing[title]" id="title" value="<%= listing.title %>">
        <label for="description">Description: </label>
        <input type="text" name="listing[description]" id="description" value="<%=listing.description%>">
        <label for="image">Image: </label>
        <input type="text" name="listing[image]" id="image" value="<%= listing.image.url %>">
        <label for="price">Prise: </label>
        <input type="text" name="listing[price]" id="price" value="<%= listing.price %>">
        <label for="location">Location: </label>
        <input type="text" name="listing[location]" id="location" value="<%= listing.location %>">
        <label for="country">Country: </label>
        <input type="text" name="listing[country]" id="country" value="<%= listing.country %>">

        <button type="submit">Update</button>
    </form>
</body>
