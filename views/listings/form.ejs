<% layout("layouts/boilarplate") %>
<body>
    <form method="post" action="http://localhost:8080/listing">
        <label for="title">Title: </label>
        <input type="text" name="listing[title]" id="title">
        <label for="description">Description: </label>
        <input type="text" name="listing[description]" id="description">
        <label for="image">Image: </label>
        <input type="text" name="listing[image]" id="image">
        <label for="price">Prise: </label>
        <input type="text" name="listing[price]" id="price">
        <label for="location">Location: </label>
        <input type="text" name="listing[location]" id="location">
        <label for="country">Country: </label>
        <input type="text" name="listing[country]" id="country">

        <button type="submit">Create</button>
    </form>
</body>
</html>