<% layout("layouts/boilarplate") %>

    <body>
        <div class="showContainer">
            <div class="card col-8 offset-2">
                <img src="<%= listing.image %>" class="card-img-top show-img" alt="listing-image">
                <div class="card-body">
                    <h5 class="card-title">
                        <%= listing.title %>
                    </h5>
                    <p class="card-text">
                        <%= listing.description %> <br>
                            &#8377;<%= listing.price.toLocaleString("en-IN") %> <br>
                                <%= listing.location %> ,
                                    <%= listing.country %>
                    </p>


                    <div class="show-form">
                        <div class=" col-1">
                            <a href="/listing/edit/<%= listing._id %>" class="btn btn-dark">Edit</a>

                        </div>
                        <div class="col-1">
                            <form method="post" action="/<%= listing._id %>?_method=DELETE">
                                <button type="submit" class="btn btn-danger">Delete</button>
                            </form>
                        </div>
                    </div>

                </div>
            </div>
        </div>
        </div>
    </body>